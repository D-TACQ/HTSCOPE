# xrmSlice.db
# macros HOST USER UUT

record(longout, "${HOST}:${UUT}:SYS:UPTIME") {
	field(DTYP, "Soft Channel")
	field(DOL,  {pva: {pv:"${UUT}:SYS:UPTIME", proc:"CP"}})
	field(OMSL, "closed_loop")
}
